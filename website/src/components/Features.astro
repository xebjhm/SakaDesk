---
import { getLangFromUrl, t } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    titleKey: 'features.multi_service.title',
    descKey: 'features.multi_service.desc',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />',
  },
  {
    titleKey: 'features.sync.title',
    descKey: 'features.sync.desc',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />',
  },
  {
    titleKey: 'features.blog.title',
    descKey: 'features.blog.desc',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />',
  },
  {
    titleKey: 'features.search.title',
    descKey: 'features.search.desc',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />',
  },
  {
    titleKey: 'features.i18n.title',
    descKey: 'features.i18n.desc',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />',
  },
  {
    titleKey: 'features.secure.title',
    descKey: 'features.secure.desc',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />',
  },
];
---

<section id="features" class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-text-primary sm:text-4xl">
        {t(lang, 'features.title')}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-secondary">
        {t(lang, 'features.subtitle')}
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map(({ titleKey, descKey, icon }) => (
        <div class="glass group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/10">
          <div class="mb-4 inline-flex rounded-xl bg-primary/10 p-3">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={icon} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary">
            {t(lang, titleKey)}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            {t(lang, descKey)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
